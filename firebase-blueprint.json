{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Maritime Risk App",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A chat session with the Gemini assistant",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "createdAt", "updatedAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single message in a chat session",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sessionId", "userId", "role", "text", "createdAt"]
    },
    "RiskAnalysis": {
      "title": "RiskAnalysis",
      "description": "A saved maritime risk analysis",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "sourcePortName": { "type": "string" },
        "destPortName": { "type": "string" },
        "riskScore": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "sourcePortName", "destPortName", "riskScore", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/chatSessions/{sessionId}": {
      "schema": { "$ref": "#/entities/ChatSession" },
      "description": "Chat sessions"
    },
    "/chatSessions/{sessionId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Messages within a chat session"
    },
    "/riskAnalyses/{analysisId}": {
      "schema": { "$ref": "#/entities/RiskAnalysis" },
      "description": "Saved risk analyses"
    }
  }
}
